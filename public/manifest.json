{
  "manifest_version": 3,
  "name": "JesSee",
  "description": "Turn narrated screen walkthroughs into polished, evidence-backed PDF tickets and guides.",
  "version": "0.1.0",
  "action": {
    "default_title": "JesSee",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "downloads",
    "sidePanel",
    "scripting",
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
